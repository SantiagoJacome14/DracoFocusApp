APP_NAME=DracoFocus
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-app.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db.XXXXXXXXXXXX.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=tu_password_supabase
DB_SSLMODE=require

# ── Sesiones / Caché / Cola ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Google OAuth (Web — Socialite) ──────────────────────────────────────────
# Crea un OAuth 2.0 Client ID en https://console.cloud.google.com
# Tipo: Aplicación web
# URI de redirección autorizada: https://tu-app.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tu-app.onrender.com/auth/google/callback

# ── Google OAuth (Mobile API — Android) ─────────────────────────────────────
# Usa el Client ID de Android desde Google Cloud Console
# El backend lo necesita para verificar el id_token que manda la app
GOOGLE_WEB_CLIENT_ID=

# ── OpenAI (para feedback con IA en lecciones) ───────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dracofocus.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS (no requerido si no se usa S3) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
